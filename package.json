{
  "name": "opero-desktop",
  "version": "1.0.0",
  "description": "Opero — Professional Workspace Management Platform",
  "main": "main.js",
  "author": {
    "name": "Opero",
    "email": "support@opero.app"
  },
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron . --dev",
    "dev": "electron . --dev",
    "dist": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux",
    "dist:all": "electron-builder --win --mac --linux"
  },
  "build": {
    "appId": "com.teamyy.desktop",
    "productName": "Teamyy",
    "copyright": "Copyright © 2026 Teamyy",
    "asar": true,
    "asarUnpack": [
      "build/**/*"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "main.js",
      "preload.js",
      "server.js",
      "build/**/*",
      "assets/**/*",
      "!node_modules/.cache/**/*",
      "!dist/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "artifactName": "${productName}.Setup.${version}.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Teamyy"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/icon.png",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "assets/icon.png",
      "category": "Office"
    },
    "publish": null
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "http-proxy-middleware": "^3.0.3"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "sharp": "^0.34.5"
  }
}
